# Exemple .env serveur Supabase (self-hosted) — SMTP Gmail + templates email

# URL publique Supabase (celle que l’app utilise)
GOTRUE_SITE_URL=https://supabase-api.hopitalia-dantec.com
GOTRUE_URI_ALLOW_LIST=https://supabase-api.hopitalia-dantec.com

# Activer l’auth email
GOTRUE_EXTERNAL_EMAIL_ENABLED=true

# SMTP Gmail (utilise un App Password)
GOTRUE_SMTP_HOST=smtp.gmail.com
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=ton.adresse@gmail.com
GOTRUE_SMTP_PASS=xxxx xxxx xxxx xxxx
GOTRUE_SMTP_ADMIN_EMAIL=ton.adresse@gmail.com
GOTRUE_SMTP_SENDER_NAME=lapiNia

# Sujet + template (UI/UX) pour les emails Supabase Auth
# Ces templates doivent être accessibles en HTTP depuis le service "auth" (GoTrue).
GOTRUE_MAILER_SUBJECTS_CONFIRMATION=Bienvenue sur lapiNia — confirmez votre email
GOTRUE_MAILER_TEMPLATES_CONFIRMATION=http://templates-server/confirmation.html

GOTRUE_MAILER_SUBJECTS_RECOVERY=lapiNia — réinitialisation de votre mot de passe
GOTRUE_MAILER_TEMPLATES_RECOVERY=http://templates-server/recovery.html

